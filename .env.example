# Copy to .env and fill in. Expo exposes only EXPO_PUBLIC_* to the client.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Magic link: add `voxa://auth/callback` to Supabase Auth → Redirect URLs (see docs/AUTH_REDIRECTS.md).
# Optional: force redirect if needed (default in app is already voxa://auth/callback).
# EXPO_PUBLIC_AUTH_REDIRECT_NATIVE=voxa://auth/callback
# Expo **web** magic link only — marketing or local web origin + path /auth/callback
# EXPO_PUBLIC_AUTH_WEB_REDIRECT_URL=https://your-site.netlify.app/auth/callback

# PostHog (client)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# RevenueCat (client)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# Full URL of the deployed `realtime-session` Edge Function (voice mode only)
# Example: https://<PROJECT_REF>.supabase.co/functions/v1/realtime-session
EXPO_PUBLIC_REALTIME_SESSION_URL=

# Text AI coach (default mode) — deploy ai-chat-coach Edge Function
# Example: https://<PROJECT_REF>.supabase.co/functions/v1/ai-chat-coach
EXPO_PUBLIC_AI_CHAT_COACH_URL=

# Optional: assistant reply playback (user taps Play voice)
# Example: https://<PROJECT_REF>.supabase.co/functions/v1/elevenlabs-tts
EXPO_PUBLIC_ELEVENLABS_TTS_URL=

# Practice mode: `text` (default, Groq/Gemini via Edge Function) or `voice` (OpenAI Realtime)
EXPO_PUBLIC_AI_MODE=text

# Set to 1 for App Store / Product Hunt screenshot builds (optional marketing banner on Practice tab).
EXPO_PUBLIC_SCREENSHOT_MODE=

# Direct Postgres (psql, local migrations). Put only in .env (gitignored); never EXPO_PUBLIC_*.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.<PROJECT_REF>.supabase.co:5432/postgres

# Server-only (Edge Functions, scripts, CI). Never EXPO_PUBLIC_* — never bundle into the app.
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# --- Server-only (Supabase Dashboard → Edge Functions → Secrets, or `supabase secrets set`) ---
# OPENAI_API_KEY=sk-...
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# VOXA_AI_PROVIDER=groq
# GROQ_API_KEY=
# GEMINI_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GEMINI_MODEL=gemini-2.0-flash-lite
# ELEVENLABS_API_KEY=   # ElevenLabs API key (usually starts with sk_)
# ELEVENLABS_MODEL=eleven_multilingual_v2
