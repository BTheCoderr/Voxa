{
  "expo": {
    "name": "Voxa",
    "slug": "voxa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "voxa",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070A12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.baheemferrell.voxa",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Voxa needs microphone access to send your voice to your realtime AI practice session. Audio is used for speaking feedback only during a session you start.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.baheemferrell.voxa",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#070A12"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-audio",
      "@edkimmel/expo-audio-stream/app.plugin.js",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c17559e4-a62e-4518-a7e8-967645362ed5"
      }
    },
    "owner": "bferrell514",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c17559e4-a62e-4518-a7e8-967645362ed5"
    }
  }
}
